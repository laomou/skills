{
  "mcpServers": {
    "memory": {
      "command": "uv",
      "args": [
        "run",
        "--project",
        "${CODEX_PLUGIN_ROOT}",
        "python",
        "${CODEX_PLUGIN_ROOT}/server.py"
      ],
      "env": {
        "LM_MEM_WEB": "on",
        "LM_MEM_WEB_HOST": "127.0.0.1",
        "LM_MEM_WEB_PORT": "7531"
      }
    }
  }
}
